{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "moduleName": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*)*$"
    },
    "direction": {
      "enum": ["asc", "desc"]
    },
    "expr": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "value"],
          "properties": {
            "op": {"const": "string"},
            "value": {"type": "string"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "value"],
          "properties": {
            "op": {"const": "int"},
            "value": {"type": "integer"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "value"],
          "properties": {
            "op": {"const": "float"},
            "value": {"type": "number"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "value"],
          "properties": {
            "op": {"const": "bool"},
            "value": {"type": "boolean"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op"],
          "properties": {
            "op": {"const": "nil"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "name"],
          "properties": {
            "op": {"const": "var"},
            "name": {"$ref": "#/$defs/name"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "target", "field"],
          "properties": {
            "op": {"const": "field"},
            "target": {"$ref": "#/$defs/expr"},
            "field": {"$ref": "#/$defs/name"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "fn", "args"],
          "properties": {
            "op": {"const": "call"},
            "fn": {"$ref": "#/$defs/name"},
            "args": {
              "type": "array",
              "items": {"$ref": "#/$defs/expr"}
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "entries"],
          "properties": {
            "op": {"const": "map"},
            "entries": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["key", "expr"],
                "properties": {
                  "key": {"$ref": "#/$defs/name"},
                  "expr": {"$ref": "#/$defs/expr"}
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "items"],
          "properties": {
            "op": {"const": "vector"},
            "items": {
              "type": "array",
              "items": {"$ref": "#/$defs/expr"}
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "bindings", "body"],
          "properties": {
            "op": {"const": "let"},
            "bindings": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name", "expr"],
                "properties": {
                  "name": {"$ref": "#/$defs/name"},
                  "expr": {"$ref": "#/$defs/expr"}
                }
              }
            },
            "body": {"$ref": "#/$defs/expr"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "condition", "then", "else"],
          "properties": {
            "op": {"const": "if"},
            "condition": {"$ref": "#/$defs/predicateExpr"},
            "then": {"$ref": "#/$defs/expr"},
            "else": {"$ref": "#/$defs/expr"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "clauses", "else"],
          "properties": {
            "op": {"const": "cond"},
            "rationale": {"type": "string"},
            "clauses": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["condition", "expr"],
                "properties": {
                  "condition": {"$ref": "#/$defs/predicateExpr"},
                  "expr": {"$ref": "#/$defs/expr"}
                }
              }
            },
            "else": {"$ref": "#/$defs/expr"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "collection", "item", "where", "select"],
          "properties": {
            "op": {"const": "query"},
            "rationale": {"type": "string"},
            "collection": {"$ref": "#/$defs/expr"},
            "item": {"$ref": "#/$defs/name"},
            "where": {
              "type": "array",
              "items": {"$ref": "#/$defs/predicateExpr"}
            },
            "sort": {
              "type": "object",
              "additionalProperties": false,
              "required": ["expr", "direction"],
              "properties": {
                "expr": {"$ref": "#/$defs/expr"},
                "direction": {"$ref": "#/$defs/direction"}
              }
            },
            "select": {"$ref": "#/$defs/expr"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "left", "right"],
          "properties": {
            "op": {"enum": ["=", "not=", ">", "<", ">=", "<="]},
            "left": {"$ref": "#/$defs/expr"},
            "right": {"$ref": "#/$defs/expr"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "args"],
          "properties": {
            "op": {"enum": ["and", "or"]},
            "args": {
              "type": "array",
              "minItems": 1,
              "items": {"$ref": "#/$defs/predicateExpr"}
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "expr"],
          "properties": {
            "op": {"const": "not"},
            "expr": {"$ref": "#/$defs/predicateExpr"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "expr"],
          "properties": {
            "op": {"enum": ["nil?", "some?"]},
            "expr": {"$ref": "#/$defs/expr"}
          }
        }
      ]
    },
    "predicateExpr": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "left", "right"],
          "properties": {
            "op": {"enum": ["=", "not=", ">", "<", ">=", "<="]},
            "left": {"$ref": "#/$defs/expr"},
            "right": {"$ref": "#/$defs/expr"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "args"],
          "properties": {
            "op": {"enum": ["and", "or"]},
            "args": {
              "type": "array",
              "minItems": 1,
              "items": {"$ref": "#/$defs/predicateExpr"}
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "expr"],
          "properties": {
            "op": {"const": "not"},
            "expr": {"$ref": "#/$defs/predicateExpr"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "expr"],
          "properties": {
            "op": {"enum": ["nil?", "some?"]},
            "expr": {"$ref": "#/$defs/expr"}
          }
        }
      ]
    },
    "def": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "args", "expr"],
      "properties": {
        "name": {"$ref": "#/$defs/name"},
        "args": {
          "type": "array",
          "items": {"$ref": "#/$defs/name"}
        },
        "expr": {"$ref": "#/$defs/expr"}
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["module", "defs"],
  "properties": {
    "module": {"$ref": "#/$defs/moduleName"},
    "defs": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/def"}
    }
  }
}
